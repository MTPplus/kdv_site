lass=\"main\">\n      <section class=\"face-section\">\n        <div class=\"container banner\">\n          <div class=\"face-block\">\n            <div class=\"face-block__title\">MICROTERM PLUS</div>\n            <div class=\"face-block__description\">\n              Modern Process Control Systems            </div><a class=\"button\" href=\"/service\">Services</a>\n          </div>\n        </div>\n      </section>\n      <section class=\"key-products-section\">\n        <div class=\"container\">\n          <div class=\"key-products\">\n            <div class=\"key-products__title\">Продукция</div>\n            <div class=\"key-products__view\">\n              <div class=\"key-products__viewer\"><img class=\"key-products__image\" src=\"https://dvkran.ru/wp-content/uploads/2023/09/product-1.png\" id=\"product-image\"></div>\n              <div class=\"key-products__list\"><a class=\"key-products__item\" href=\"/\" onmouseover=\"changeImage('https://dvkran.ru/wp-content/uploads/2023/09/product-1.png')\">\n                  <div class=\"key-products__type\">Краны козловые</div></a><a class=\"key-products__item\" href=\"/\" onmouseover=\"changeImage('https://dvkran.ru/wp-content/uploads/2023/09/product-2.png')\"> \n                  <div class=\"key-products__type\">Краны мостовые </div></a><a class=\"key-products__item\" href=\"/\" onmouseover=\"changeImage('https://dvkran.ru/wp-content/uploads/2023/09/product-3.png')\"> \n                  <div class=\"key-products__type\">Кран-балки</div></a><a class=\"key-products__item\" href=\"/\" onmouseover=\"changeImage('https://dvkran.ru/wp-content/uploads/2023/09/product-4.png')\">\n                  <div class=\"key-products__type\">Крановые кабины</div></a><a class=\"key-products__item\" href=\"/\" onmouseover=\"changeImage('https://dvkran.ru/wp-content/uploads/2023/09/product-5.png')\"> \n                  <div class=\"key-products__type\">Кресло-пульты</div></a><a class=\"key-products__item\" href=\"/\" onmouseover=\"changeImage('https://dvkran.ru/wp-content/uploads/2023/09/product-6.png')\"> \n                  <div class=\"key-products__type\">Аппаратные помещения</div></a><a class=\"key-products__item\" href=\"/\" onmouseover=\"changeImage('https://dvkran.ru/wp-content/uploads/2023/09/product-7.png')\"> \n                  <div class=\"key-products__type\">Аппаратные помещения</div></a><a class=\"key-products__item\" href=\"/\" onmouseover=\"changeImage('https://dvkran.ru/wp-content/uploads/2023/09/product-8.png')\"> \n                  <div class=\"key-products__type\">Вспомогательное оборудование</div></a></div>\n            </div>\n          </div>\n        </div>\n      </section>\n      <section class=\"services-section\">\n        <div class=\"container\">\n          <div class=\"services\">\n            <div class=\"title services__title\">Инжиниринговые услуги</div>\n            <div class=\"services__list\"><a class=\"services__item\" id=\"product-image\" href=\"/service\">\n                <div class=\"single-element__image\"><img src=\"https://dvkran.ru/wp-content/uploads/2023/09/service-1.png\"></div>\n                <div class=\"single-element__link\">\n                  <div class=\"single-element__title\">Проектирование подъёмно-транспортного оборудования</div>\n                  <div class=\"button-transparent single-element__button\">Подробнее</div>\n                </div></a><a class=\"services__item\" href=\"/service\"> \n                <div class=\"single-element__image\"><img src=\"https://dvkran.ru/wp-content/uploads/2023/09/service-2.png\"></div>\n                <div class=\"single-element__link\" href=\"/service\"> \n                  <div class=\"single-element__title\">Техническое обслуживание</div>\n                  <div class=\"button-transparent single-element__button\">Подробнее</div>\n                </div></a><a class=\"services__item\" href=\"/service\"> \n                <div class=\"single-element__image\"><img src=\"https://dvkran.ru/wp-content/uploads/2023/09/service-3.png\"></div>\n                <div class=\"single-element__link\" href=\"/service\"> \n                  <div class=\"single-element__title\">Модернизация кранов</div>\n                  <div class=\"button-transparent single-element__button\">Подробнее</div>\n                </div></a><a class=\"services__item\" href=\"/service\"> \n                <div class=\"single-element__image\"><img src=\"https://dvkran.ru/wp-content/uploads/2023/09/service-4.png\"></div>\n                <div class=\"single-element__link\" href=\"/service\"> \n                  <div class=\"single-element__title\">Монтаж</div>\n                  <div class=\"button-transparent single-element__button\">Подробнее</div>\n                </div></a><a class=\"services__item\" href=\"/service\"> \n                <div class=\"single-element__image\"><img src=\"https://dvkran.ru/wp-content/uploads/2023/09/service-5.png\"></div>\n                <div class=\"single-element__link\" href=\"/service\"> \n                  <div class=\"single-element__title\">Доставка</div>\n                  <div class=\"button-transparent single-element__button\">Подробнее</div>\n                </div></a><a class=\"services__item\" href=\"/service\"> \n                <div class=\"single-element__image\"><img src=\"https://dvkran.ru/wp-content/uploads/2023/09/service-6.png\"></div>\n                <div class=\"single-element__link\" href=\"/service\"> \n                  <div class=\"single-element__title\">Лизинг</div>\n                  <div class=\"button-transparent single-element__button\">Подробнее</div>\n                </div></a></div>\n          </div>\n        </div>\n      </section>\n      <section class=\"our-projects-section\">\n        <div class=\"container\">\n          <div class=\"project__header-tittle\">Наши проекты</div>\n          <div class=\"project__list\"> <a class=\"project__item\" href=\"/\"><img class=\"project__img\" src=\"https://dvkran.ru/wp-content/uploads/2023/09/product-1.png\">\n              <div class=\"project__text-area\">\n                <div class=\"project__tittle\">Кран козловой (10&nbsp;тонн) для&nbsp;Меркурий&nbsp;ДВ</div>\n                <div class=\"project__text\">Кран козловой электрический КК-16+16; режима работы А5; пролётом 20,5 м; управлением с пола по радиоканалу</div>\n              </div></a><a class=\"project__item\" href=\"/\"><img class=\"project__img\" src=\"https://dvkran.ru/wp-content/uploads/2023/09/product-3.png\">\n              <div class=\"project__text-area\">\n                <div class=\"project__tittle\">Кран козловой (16&nbsp;тонн + 16&nbsp;тонн) для&nbsp;Корфовского каменного карьера</div>\n                <div class=\"project__text\">\n                  Кран мостовой однобалочный опорный г/п 8 т. пролёт 11,15 м. высота подъёма 5 м. режим работы А3</div>\n              </div></a><a class=\"project__item\" href=\"/\"><img class=\"project__img\" src=\"https://dvkran.ru/wp-content/uploads/2023/09/product-2.png\">\n              <div class=\"project__text-area\">\n                <div class=\"project__tittle\">Кран козловой (10&nbsp;тонн) для&nbsp;АО&nbsp;«БЭТ»</div>\n                <div class=\"project__text\">Кран козловой электрический КК-16+16; режима работы А5; пролётом 20,5 м; управлением с пола по радиоканалу</div>\n              </div></a><a class=\"project__item\" href=\"/\"><img class=\"project__img\" src=\"https://dvkran.ru/wp-content/uploads/2023/09/product-4.png\">\n              <div class=\"project__text-area\">\n                <div class=\"project__tittle\">Кран мостовой (16&nbsp;тонн) для&nbsp;«Хабаровск Автомост»</div>\n                <div class=\"project__text\">Кран мостовой однобалочный опорный г/п 8 т. пролёт 11,15 м. высота подъёма 5 м. режим работы А3</div>\n              </div></a></div>\n          <div class=\"project__file\"> <a class=\"project__button\" href=\"https://drive.google.com/file/d/1HalIDIAwc5oqhoHxim3A78mnr8v51ahx/view\">Скачать р